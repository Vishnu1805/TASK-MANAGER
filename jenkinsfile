pipeline {
    agent any

    tools {
        nodejs 'NodeJS18'
    }

    environment {
        EXPO_USE_STATIC_WEBPACK_CONFIG = "1"
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/Vishnu1805/TASK-MANAGER.git'
            }
        }


        stage('Install Dependencies') {
            steps {
                sh '''
                npm ci
                npm cache clean --force
                '''
            }
        }

        stage('Build Expo Web') {
            steps {
                sh '''
                npx expo export -p web --output-dir web-build
                '''
            }
        }

        stage('Run Application') {
            steps {
                sh '''
                npm install -g serve
                serve -s web-build -l 3000 &
                '''
            }
        }

    }

    post {
        success {
            echo "Application Build and Run Successful"
        }
        failure {
            echo "Pipeline Failed"
        }
    }
}




